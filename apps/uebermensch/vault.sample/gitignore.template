# This file is installed as `.gitignore` when `gctrl uber vault init --from-sample`
# copies the sample vault into $UBER_VAULT_DIR. It is kept as a `.template`
# inside gctrl repo so that vault.sample/wiki/ + briefs/ sample content stays
# tracked for reference.

# Generated content (LLM + app) — synced via R2, not git
/wiki/
/briefs/

# App metadata
/.gctrl-uber/

# Obsidian per-machine state (plugin data, workspace layout)
/.obsidian/workspace*.json
/.obsidian/plugins/*/data.json
/.obsidian/plugins/*/data-*.json
